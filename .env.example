# Local development configuration. Copy to .env and adapt as needed.
GAME_SIMULATOR_HOST=127.0.0.1
GAME_SIMULATOR_PORT=4000
GAME_SIMULATOR_LOG_DIR=log
GAME_SIMULATOR_LOG_LEVEL=debug
GAME_SIMULATOR_DATA_DIR=data
GAME_SIMULATOR_TOKEN_TTL_SECONDS=3600

# Optional legacy import path. Users are stored in SQLite after import.
# GAME_SIMULATOR_USERS_FILE=data/users

# Optional: required only when a feature makes an LLM request.
GAME_SIMULATOR_LLM_ENABLED=false
GAME_SIMULATOR_LLM_TIMEOUT_MS=1500
# GAME_SIMULATOR_LLM_API_KEY=
